{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and savings settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "phone": { "type": "string", "description": "Phone number" },
        "savingsMode": { "type": "string", "enum": ["arrondi", "pourcentage", "fixe"], "description": "Selected savings mode" },
        "savingsValue": { "type": "number", "description": "Value for the savings mode (e.g. 10 for 10%)" },
        "operator": { "type": "string", "enum": ["mtn", "moov", "wave"], "description": "Mobile money operator" },
        "totalSaved": { "type": "number", "description": "Total amount saved across all goals" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "phone", "savingsMode", "operator"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A savings goal for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "category": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "targetAmount", "currentAmount"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A savings transaction (simulated API withdrawal)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "goalId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "operator": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Savings goals"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Savings transactions history"
    }
  }
}
